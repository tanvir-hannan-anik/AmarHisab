# ── Dependencies ─────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/
.pnp.cjs
.pnp.loader.mjs

# ── Environment files (never commit secrets) ─────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
# keep .env.example committed so others know what vars are needed

# ── SQLite database files ────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
server/data/*.db
server/data/*.db-shm
server/data/*.db-wal

# ── Build / cache output ─────────────────────────────────
dist/
build/
.next/
.nuxt/
.cache/
.parcel-cache/
out/
.turbo/

# ── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ── Coverage ─────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Editor / IDE ─────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.history/

# ── OS junk ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Render / deployment artifacts ────────────────────────
.render/
.vercel/
.netlify/
.firebase/
firebase-debug.log
firebase-debug.*.log

# ── Misc ─────────────────────────────────────────────────
*.tgz
.npm/
.eslintcache
.tsbuildinfo
