# Amar Hisab Server — Environment Variables
# Copy this to .env and fill in your values.

# Port the server listens on
PORT=4000

# JWT signing secret. MUST be a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-in-production

# JWT token lifetime
JWT_EXPIRES=30d

# CORS origin(s) — comma-separated. Use * only in development.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500

# SQLite database file path (relative to server/ or absolute)
DB_PATH=./data/amar-hisab.db

# bcrypt cost (10-12 in prod)
BCRYPT_ROUNDS=10
